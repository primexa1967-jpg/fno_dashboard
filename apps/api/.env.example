# Dhan API Configuration
DHAN_API_KEY=
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# JWT Configuration
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# Admin Seed
ADMIN_SEED_EMAIL=primexa1967@gmail.com
ADMIN_SEED_PASSWORD=ChangeMe!123

# Plan Settings
FREE_TRIAL_DAYS=30
TAX_PERCENT=18

# Server Configuration
PORT=4000
NODE_ENV=development

# Mock Mode — MUST be false in production (real Dhan data only)
MOCK_MODE=false

# Require JWT on /market/* (default: on when NODE_ENV=production). Set true locally to test auth.
# REQUIRE_MARKET_AUTH=false

# Comma-separated origins for browser requests (production)
# CORS_ORIGINS=https://primexalearning.in,https://www.primexalearning.in

# Risk-free rate for Greeks calculation (as decimal, e.g., 0.05 for 5%)
RISK_FREE_RATE=0.05

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
